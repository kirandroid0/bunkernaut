# Copy to android/keystore.properties (never commit that file).
# Generate keystore:
#   keytool -genkeypair -alias bunkernaut -keyalg RSA -keysize 2048 -validity 10000 -keystore bunkernaut-upload.keystore

storeFile=../bunkernaut-upload.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=bunkernaut
keyPassword=YOUR_KEY_PASSWORD
